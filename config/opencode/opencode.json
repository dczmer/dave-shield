{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": "notify",
  "model": "opencode-go/glm-5",
  "small_model": "opencode-go/minimax-m2.5",
  "share": "disabled",
  "snapshot": false,
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  },
  "permission": {
    "*": "ask",
    "external_directory": {
      "*": "ask",
      "/tmp/*": "allow"
    },
    "read": {
      "*": "allow"
    },
    "edit": {
      "*": "allow"
    },
    "glob": {
      "*": "allow"
    },
    "grep": {
      "*": "allow"
    },
    "list": {
      "*": "allow"
    },
    "bash": {
      "*": "ask",
      "echo *": "allow",
      "cat *": "allow",
      "ls *": "allow",
      "wc *": "allow",
      "grep *": "allow",
      "find *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "touch *": "allow",
      "gh issue view*": "allow",
      "gh issue list*": "allow",
      "git status*": "allow",
      "git add*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git show*": "allow",
      "git checkout -b *": "allow",
      "nix run .*": "allow"
    },
    "task": {
      "*": "allow"
    },
    "skill": {
      "*": "allow",
      "experimental-*": "deny",
      "internal-*": "ask"
    }
  },
  "watcher": {
    "ignore": [
      ".git",
      "node_modules",
      "target",
      "build"
    ]
  }
}
