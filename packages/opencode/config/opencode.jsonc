{
  "$schema": "https://opencode.ai/config.json",
  // expected that we are running in a container or sandbox.
  // always prompt for external directories as a secondary safety layer.
  "permission": {
    "*": "ask",
    "external_directory": {
      "*": "ask",
      "~/tmp/*": "ask",
      "/tmp/*": "allow"
    },
    "read": {
      "*": "allow"
    },
    "edit": {
      "*": "allow"
    },
    "glob": {
      "*": "allow"
    },
    "grep": {
      "*": "allow"
    },
    "list": {
      "*": "allow"
    },
    "bash": {
      "*": "ask",
      "echo *": "allow",
      "cat *": "allow",
      "ls": "allow",
      "ls *": "allow",
      "echo *": "allow",
      "wc *": "allow",
      "grep *": "allow",
      "find *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "touch *": "allow",
      "mkdir *": "allow",
      "gh issue view *": "allow",
      "gh issue list *": "allow",
      "git status*": "allow",
      "git add *": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git rev-parse *": "allow",
      "git show*": "allow",
      "git checkout *": "allow",
      "nix run .*": "allow",
      "luacheck *": "allow",
      "stylua *": "allow",
      "rtk *": "allow",
      "cd *": "allow",
      "sed *": "allow",
      "true": "allow",
      "mv *": "allow",
      "pwd": "allow",
      "rg *": "allow",
      "cp *": "allow",
      "awk *": "allow",
      "xargs *": "allow",
      "sort *": "allow",
      "which *": "allow",
      "date": "allow",
      "date *": "allow",
      "jq *": "allow",
      "ps *": "allow",
      "nixfmt*": "allow",
      "git -C *": "allow",
    },
    "task": {
      "*": "allow"
    },
    "skill": {
      "*": "allow",
      "experimental-*": "deny",
      "internal-*": "ask"
    }
  },
  "plugin": [ "superpowers@git+https://github.com/obra/superpowers.git" ],
}
