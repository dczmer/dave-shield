{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "*": "ask",
    "external_directory": {
      "*": "ask",
      "/tmp/*": "allow"
    },
    "read": {
      "*": "allow"
    },
    "edit": {
      "*": "allow"
    },
    "glob": {
      "*": "allow"
    },
    "grep": {
      "*": "allow"
    },
    "list": {
      "*": "allow"
    },
    "bash": {
      "*": "ask",
      "echo *": "allow",
      "cat *": "allow",
      "ls *": "allow",
      "wc *": "allow",
      "grep *": "allow",
      "find *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "touch *": "allow",
      "mkdir *": "allow",
      "gh issue view *": "allow",
      "gh issue list *": "allow",
      "git status*": "allow",
      "git add *": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git rev-parse *": "allow",
      "git show*": "allow",
      "git checkout *": "allow",
      "nix run .*": "allow",
      "luacheck *": "allow",
      "stylua *": "allow",
      "rtk *": "allow"
    },
    "task": {
      "*": "allow"
    },
    "skill": {
      "*": "allow",
      "experimental-*": "deny",
      "internal-*": "ask"
    }
  },
  "plugin": [ "superpowers@git+https://github.com/obra/superpowers.git" ],
}
