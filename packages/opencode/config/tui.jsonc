{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": "notify",
  "permission": {
    "*": "ask",
    "websearch": "ask",
  },
  "provider": {
    "llama.cpp": {
      "name": "llama-server (local)",
      "options": {
        "baseURL": "http://127.0.0.1:11434/v1",
      },
      "models": {
        "unsloth_Qwen3.5-9B-UD-Q4_K_XL": {
          "limit": {
            "context": 252144,
            "output": 32768,
          },
        },
      },
    },
  },
  "model": "opencode-go/kimi-k2.5",
  "small_model": "opencode-go/minimax-2.5",
  "watcher": {
    "ignore": [".git", "node_modules", "target", "build"],
  },
}
